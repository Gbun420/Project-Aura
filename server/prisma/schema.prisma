generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Job {
  id          Int     @id @default(autoincrement())
  title       String?
  company     String?
  location    String?
  sector      String?
  salary      String?
  description String?

  @@map("jobs")
}

model PermitStatus {
  userId      String   @id @map("user_id")
  currentStep Int      @default(1) @map("current_step")
  lastUpdated DateTime @default(now()) @map("last_updated")

  @@map("permit_status")
}

model IntroductionLedger {
  hash        String    @id
  employerId  String?   @map("employer_id")
  candidateId String?   @map("candidate_id")
  notifiedAt  DateTime  @default(now()) @map("notified_at")
  expiryDate  DateTime? @map("expiry_date")
  feeStatus   String?   @default("PENDING") @map("fee_status")

  @@map("introduction_ledger")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  eventType String?  @map("event_type")
  details   String?
  signature String?
  timestamp DateTime @default(now())

  @@map("audit_log")
}

// --- Compliance & Regulatory Models (2026 Mandates) ---

model ComplianceRecord {
  id              String    @id @default(uuid())
  entityId        String    @map("entity_id") // Employer or Agency ID
  licenseNumber   String?   @map("license_number")
  licenseStatus   String    @default("PENDING") @map("license_status")
  lastAuditDate   DateTime? @map("last_audit_date")
  nextAuditDate   DateTime? @map("next_audit_date")
  guaranteeAmount Decimal?  @map("guarantee_amount")
  competentPerson String?   @map("competent_person")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  @@map("compliance_records")
}

model UserConsent {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  consentType String    @map("consent_type") // e.g., "COOKIES", "MARKETING", "DATA_PROCESSING"
  status      String    @map("status") // "GRANTED", "WITHDRAWN"
  ipAddress   String?   @map("ip_address")
  userAgent   String?   @map("user_agent")
  grantedAt   DateTime  @default(now()) @map("granted_at")
  withdrawnAt DateTime? @map("withdrawn_at")
  version     String    @default("1.0") // Policy version

  @@map("user_consent")
}

model AuditTrail {
  id           String   @id @default(uuid())
  action       String
  entityType   String   @map("entity_type") // "USER", "SYSTEM", "ADMIN"
  entityId     String   @map("entity_id")
  resourceType String?  @map("resource_type") // "JOB", "CANDIDATE", "CONSENT"
  resourceId   String?  @map("resource_id")
  details      Json?
  ipAddress    String?  @map("ip_address")
  timestamp    DateTime @default(now())

  @@map("audit_trails")
}

model RegulatoryUpdate {
  id            String   @id @default(uuid())
  title         String
  description   String
  source        String? // "DIER", "Identità", "EU"
  effectiveDate DateTime @map("effective_date")
  category      String? // "TAX", "PERMIT", "DATA"
  createdAt     DateTime @default(now()) @map("created_at")

  @@map("regulatory_updates")
}

model ComplianceReport {
  id          String   @id @default(uuid())
  generatedBy String   @map("generated_by")
  reportType  String   @map("report_type") // "WEEKLY", "AUDIT", "INCIDENT"
  data        Json
  status      String   @default("GENERATED")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("compliance_reports")
}

model CandidateProfile {
  id              String    @id @default(uuid())
  pdcRef          String?   @map("pdc_ref")
  pdcExpiryDate   DateTime? @map("pdc_expiry_date")
  encryptedData   String?   @map("encrypted_data")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("candidate_profiles")
}
