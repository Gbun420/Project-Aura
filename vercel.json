{
  "version": 2,
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        {
          "key": "Content-Security-Policy",
          "value": "default-src 'self' https://*.supabase.co; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://*.supabase.co https://vercel.live; font-src 'self' https://fonts.gstatic.com https://r2cdn.perplexity.ai data:; frame-src 'self' https://vercel.live; connect-src 'self' https://*.supabase.co wss://*.supabase.co https://vercel.live; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com;"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/assets/(.*)", "destination": "/assets/$1" },
    { "source": "/manifest.json", "destination": "/manifest.json" },
    { "source": "/manifest.webmanifest", "destination": "/manifest.webmanifest" },
    { "source": "/registerSW.js", "destination": "/registerSW.js" },
    { "source": "/sw.js", "destination": "/sw.js" },
    { "source": "/vite.svg", "destination": "/vite.svg" },
    { "source": "/workbox-(.*).js", "destination": "/workbox-$1.js" },
    { "source": "/portal/(.*)", "destination": "/" },
    { "source": "/login", "destination": "/" },
    { "source": "/register", "destination": "/" },
    { "source": "/compliance", "destination": "/" },
    { "source": "/(.*)", "destination": "/" }
  ]
}
